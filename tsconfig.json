{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": [
      "ES2022",
      "DOM"
    ],
    "paths": {
      "@deck-shelves/host": ["./host/src/contract/index.ts"],
      "@deck-shelves/api": ["./api/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "i18n/**/*.json"
  ],
  "exclude": [
    "dist",
    "out",
    "node_modules"
  ]
}
