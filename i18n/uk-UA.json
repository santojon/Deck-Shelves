  "docs_filter_name_regex_desc": "\u041f\u043e\u043a\u0430\u0437\u0443\u0454 \u0456\u0433\u0440\u0438, \u043d\u0430\u0437\u0432\u0430 \u044f\u043a\u0438\u0445 \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u0430\u0454 \u0448\u0430\u0431\u043b\u043e\u043d\u0443 \u0440\u0435\u0433\u0443\u043b\u044f\u0440\u043d\u043e\u0433\u043e \u0432\u0438\u0440\u0430\u0437\u0443.",
  "docs_filter_played_within_desc": "\u041f\u043e\u043a\u0430\u0437\u0443\u0454 \u0456\u0433\u0440\u0438, \u0432 \u044f\u043a\u0456 \u0433\u0440\u0430\u043b\u0438 \u043f\u0440\u043e\u0442\u044f\u0433\u043e\u043c \u043e\u0441\u0442\u0430\u043d\u043d\u0456\u0445 N \u0434\u043d\u0456\u0432.",
  "docs_filter_playtime_range_desc": "\u041f\u043e\u043a\u0430\u0437\u0443\u0454 \u0456\u0433\u0440\u0438 \u0437 \u0437\u0430\u0433\u0430\u043b\u044c\u043d\u0438\u043c \u0447\u0430\u0441\u043e\u043c \u0433\u0440\u0438 \u043c\u0456\u0436 \u043c\u0456\u043d\u0456\u043c\u0443\u043c\u043e\u043c \u0442\u0430 \u043c\u0430\u043a\u0441\u0438\u043c\u0443\u043c\u043e\u043c (\u0443 \u0445\u0432\u0438\u043b\u0438\u043d\u0430\u0445).",
  "docs_filter_collection_desc": "\u041f\u043e\u043a\u0430\u0437\u0443\u0454 \u0456\u0433\u0440\u0438, \u0449\u043e \u043d\u0430\u043b\u0435\u0436\u0430\u0442\u044c \u0434\u043e \u043f\u0435\u0432\u043d\u043e\u0457 \u043a\u043e\u043b\u0435\u043a\u0446\u0456\u0457 Steam.",
  "docs_filter_store_tag_desc": "\u0424\u0456\u043b\u044c\u0442\u0440 \u0437\u0430 \u0442\u0435\u0433\u0430\u043c\u0438 \u043c\u0430\u0433\u0430\u0437\u0438\u043d\u0443 Steam (\u043d\u0430\u043f\u0440. RPG, Indie, Action). \u041f\u043e\u0442\u0440\u0456\u0431\u043d\u0456 \u0434\u0430\u043d\u0456 \u0442\u0435\u0433\u0456\u0432 \u0437\u0456 Steam.",
  "docs_filter_friends_desc": "\u041f\u043e\u043a\u0430\u0437\u0443\u0454 \u0456\u0433\u0440\u0438, \u0432 \u044f\u043a\u0456 \u0433\u0440\u0430\u044e\u0442\u044c \u0432\u0430\u0448\u0456 \u0434\u0440\u0443\u0437\u0456. \u041f\u043e\u0442\u0440\u0456\u0431\u0435\u043d \u0441\u0443\u043c\u0456\u0441\u043d\u0438\u0439 \u043f\u043b\u0430\u0433\u0456\u043d \u0434\u043b\u044f \u0434\u0430\u043d\u0438\u0445 \u043f\u0440\u043e \u0434\u0440\u0443\u0437\u0456\u0432.",
  "docs_filter_achievements_desc": "\u0424\u0456\u043b\u044c\u0442\u0440 \u0437\u0430 \u043a\u0456\u043b\u044c\u043a\u0456\u0441\u0442\u044e \u0434\u043e\u0441\u044f\u0433\u043d\u0435\u043d\u044c \u0430\u0431\u043e \u0432\u0438\u043a\u043e\u043d\u0430\u043d\u043d\u044f\u043c. \u041f\u043e\u0442\u0440\u0456\u0431\u0435\u043d \u0441\u0443\u043c\u0456\u0441\u043d\u0438\u0439 \u043f\u043b\u0430\u0433\u0456\u043d.",
  "docs_filter_merge_desc": "\u041f\u043e\u0454\u0434\u043d\u0430\u0439\u0442\u0435 \u043a\u0456\u043b\u044c\u043a\u0430 \u043f\u0456\u0434\u0444\u0456\u043b\u044c\u0442\u0440\u0456\u0432 \u0443 \u0432\u043a\u043b\u0430\u0434\u0435\u043d\u0443 \u0433\u0440\u0443\u043f\u0443 \u0437 \u0432\u043b\u0430\u0441\u043d\u043e\u044e \u043b\u043e\u0433\u0456\u043a\u043e\u044e AND/OR.",
  "docs_filters_groups_title": "\u0413\u0440\u0443\u043f\u0438 \u0444\u0456\u043b\u044c\u0442\u0440\u0456\u0432",
  "docs_filters_groups_desc": "\u0424\u0456\u043b\u044c\u0442\u0440\u0438 \u043c\u043e\u0436\u043d\u0430 \u043f\u043e\u0454\u0434\u043d\u0443\u0432\u0430\u0442\u0438 \u0437\u0430 \u043b\u043e\u0433\u0456\u043a\u043e\u044e AND (\u0432\u0441\u0456 \u043f\u043e\u0432\u0438\u043d\u043d\u0456 \u0437\u0431\u0456\u0433\u0430\u0442\u0438\u0441\u044f) \u0430\u0431\u043e OR (\u0431\u0443\u0434\u044c-\u044f\u043a\u0438\u0439 \u043f\u043e\u0432\u0438\u043d\u0435\u043d \u0437\u0431\u0456\u0433\u0430\u0442\u0438\u0441\u044f). \u0412\u0438 \u0442\u0430\u043a\u043e\u0436 \u043c\u043e\u0436\u0435\u0442\u0435 \u0456\u043d\u0432\u0435\u0440\u0442\u0443\u0432\u0430\u0442\u0438 \u043e\u043a\u0440\u0435\u043c\u0456 \u0444\u0456\u043b\u044c\u0442\u0440\u0438 \u0434\u043b\u044f \u0432\u0438\u043a\u043b\u044e\u0447\u0435\u043d\u043d\u044f \u0437\u0431\u0456\u0433\u0456\u0432 \u0442\u0430 \u0432\u043a\u043b\u0430\u0434\u0430\u0442\u0438 \u0433\u0440\u0443\u043f\u0438 \u0437\u0430 \u0434\u043e\u043f\u043e\u043c\u043e\u0433\u043e\u044e \u0444\u0456\u043b\u044c\u0442\u0440\u0430 \u043e\u0431\u02bc\u0454\u0434\u043d\u0430\u043d\u043d\u044f \u0434\u043b\u044f \u0441\u043a\u043b\u0430\u0434\u043d\u0438\u0445 \u0437\u0430\u043f\u0438\u0442\u0456\u0432.",
  "docs_sort_alpha_desc": "\u0421\u043e\u0440\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0456\u0433\u043e\u0440 \u0437\u0430 \u0430\u043b\u0444\u0430\u0432\u0456\u0442\u043e\u043c \u0437\u0430 \u0432\u0456\u0434\u043e\u0431\u0440\u0430\u0436\u0443\u0432\u0430\u043d\u043e\u044e \u043d\u0430\u0437\u0432\u043e\u044e.",
  "docs_sort_recent_desc": "\u0421\u043e\u0440\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0437\u0430 \u043e\u0441\u0442\u0430\u043d\u043d\u044c\u043e\u044e \u0456\u0433\u0440\u043e\u0432\u043e\u044e \u0441\u0435\u0441\u0456\u0454\u044e (\u043e\u0441\u0442\u0430\u043d\u043d\u044f \u0437\u0456\u0433\u0440\u0430\u043d\u0430 \u043f\u0435\u0440\u0448\u043e\u044e).",
