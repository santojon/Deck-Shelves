  "docs_sort_release_date_desc": "\u0421\u043e\u0440\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0437\u0430 \u043e\u0440\u0438\u0433\u0456\u043d\u0430\u043b\u044c\u043d\u043e\u044e \u0434\u0430\u0442\u043e\u044e \u0432\u0438\u0445\u043e\u0434\u0443 (\u043d\u0430\u0439\u043d\u043e\u0432\u0456\u0448\u0456 \u043f\u0435\u0440\u0448\u0438\u043c\u0438).",
  "docs_sort_size_desc": "\u0421\u043e\u0440\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0437\u0430 \u0440\u043e\u0437\u043c\u0456\u0440\u043e\u043c \u0432\u0441\u0442\u0430\u043d\u043e\u0432\u043b\u0435\u043d\u043d\u044f \u043d\u0430 \u0434\u0438\u0441\u043a\u0443 (\u043d\u0430\u0439\u0431\u0456\u043b\u044c\u0448\u0456 \u043f\u0435\u0440\u0448\u0438\u043c\u0438).",
  "docs_sort_metacritic_desc": "\u0421\u043e\u0440\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0437\u0430 \u043e\u0446\u0456\u043d\u043a\u043e\u044e Metacritic (\u043d\u0430\u0439\u0432\u0438\u0449\u0456 \u043f\u0435\u0440\u0448\u0438\u043c\u0438).",
  "docs_sort_review_desc": "\u0421\u043e\u0440\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0437\u0430 \u043e\u0446\u0456\u043d\u043a\u043e\u044e \u0432\u0456\u0434\u0433\u0443\u043a\u0456\u0432 \u043a\u043e\u0440\u0438\u0441\u0442\u0443\u0432\u0430\u0447\u0456\u0432 Steam (\u043d\u0430\u0439\u0432\u0438\u0449\u0456 \u043f\u0435\u0440\u0448\u0438\u043c\u0438)."
