  "about_feature_duplicate": "\u0414\u0443\u0431\u043b\u044e\u0439\u0442\u0435 \u043f\u043e\u043b\u0438\u0446\u0456 \u0434\u043b\u044f \u0448\u0432\u0438\u0434\u043a\u043e\u0433\u043e \u0441\u0442\u0432\u043e\u0440\u0435\u043d\u043d\u044f \u0432\u0430\u0440\u0456\u0430\u0446\u0456\u0439",
  "about_feature_compat": "\u041f\u043e\u043a\u0430\u0437\u0443\u0454 \u0437\u043d\u0430\u0447\u043a\u0438 \u0441\u0443\u043c\u0456\u0441\u043d\u043e\u0441\u0442\u0456 Steam Deck \u043d\u0430 \u043a\u0430\u0440\u0442\u043a\u0430\u0445 \u0456\u0433\u043e\u0440",
  "about_feature_playtime": "\u041f\u043e\u043a\u0430\u0437\u0443\u0454 \u0437\u0430\u0433\u0430\u043b\u044c\u043d\u0438\u0439 \u0447\u0430\u0441 \u0433\u0440\u0438 \u043d\u0430 \u0432\u0438\u0434\u0456\u043b\u0435\u043d\u0438\u0445 \u043a\u0430\u0440\u0442\u043a\u0430\u0445 \u0456\u0433\u043e\u0440",
  "about_howto_title": "\u042f\u043a \u043a\u043e\u0440\u0438\u0441\u0442\u0443\u0432\u0430\u0442\u0438\u0441\u044f",
  "about_howto_step1": "\u0412\u0456\u0434\u043a\u0440\u0438\u0439\u0442\u0435 \u041c\u0435\u043d\u044e \u0448\u0432\u0438\u0434\u043a\u043e\u0433\u043e \u0434\u043e\u0441\u0442\u0443\u043f\u0443 (\u043a\u043d\u043e\u043f\u043a\u0430 ...) \u0456 \u0437\u043d\u0430\u0439\u0434\u0456\u0442\u044c Deck Shelves \u0443 \u0441\u043f\u0438\u0441\u043a\u0443 \u043f\u043b\u0430\u0433\u0456\u043d\u0456\u0432.",
  "about_howto_step2": "\u0423\u0432\u0456\u043c\u043a\u043d\u0456\u0442\u044c \u0433\u043e\u043b\u043e\u0432\u043d\u0438\u0439 \u043f\u0435\u0440\u0435\u043c\u0438\u043a\u0430\u0447, \u0449\u043e\u0431 \u0430\u043a\u0442\u0438\u0432\u0443\u0432\u0430\u0442\u0438 \u043f\u043e\u043b\u0438\u0446\u0456 \u043d\u0430 \u0413\u043e\u043b\u043e\u0432\u043d\u043e\u043c\u0443 \u0435\u043a\u0440\u0430\u043d\u0456.",
  "about_howto_step3": "\u041d\u0430\u0442\u0438\u0441\u043d\u0456\u0442\u044c \u043a\u043d\u043e\u043f\u043a\u0443 +, \u0449\u043e\u0431 \u0441\u0442\u0432\u043e\u0440\u0438\u0442\u0438 \u043d\u043e\u0432\u0443 \u043f\u043e\u043b\u0438\u0446\u044e. \u041e\u0431\u0435\u0440\u0456\u0442\u044c \u043d\u0430\u0437\u0432\u0443, \u0434\u0436\u0435\u0440\u0435\u043b\u043e (\u043a\u043e\u043b\u0435\u043a\u0446\u0456\u044e, \u0440\u043e\u0437\u0434\u0456\u043b \u0431\u0456\u0431\u043b\u0456\u043e\u0442\u0435\u043a\u0438 \u0430\u0431\u043e \u0444\u0456\u043b\u044c\u0442\u0440) \u0456 \u0432\u0441\u0442\u0430\u043d\u043e\u0432\u0456\u0442\u044c \u043b\u0456\u043c\u0456\u0442 \u0456\u0433\u043e\u0440.",
  "about_howto_step4": "\u0412\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0439\u0442\u0435 \u043a\u043d\u043e\u043f\u043a\u0443 \u22ef \u043d\u0430 \u043a\u043e\u0436\u043d\u0456\u0439 \u043f\u043e\u043b\u0438\u0446\u0456, \u0449\u043e\u0431 \u0440\u0435\u0434\u0430\u0433\u0443\u0432\u0430\u0442\u0438, \u0434\u0443\u0431\u043b\u044e\u0432\u0430\u0442\u0438, \u043f\u0435\u0440\u0435\u0432\u043f\u043e\u0440\u044f\u0434\u043a\u043e\u0432\u0443\u0432\u0430\u0442\u0438, \u043f\u043e\u043a\u0430\u0437\u0443\u0432\u0430\u0442\u0438/\u043f\u0440\u0438\u0445\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u0430\u0431\u043e \u0432\u0438\u0434\u0430\u043b\u044f\u0442\u0438.",
  "about_howto_step5": "\u0412\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0439\u0442\u0435 \u0456\u043c\u043f\u043e\u0440\u0442/\u0435\u043a\u0441\u043f\u043e\u0440\u0442 \u0434\u043b\u044f \u0440\u0435\u0437\u0435\u0440\u0432\u043d\u043e\u0433\u043e \u043a\u043e\u043f\u0456\u044e\u0432\u0430\u043d\u043d\u044f \u0430\u0431\u043e \u043f\u043e\u0448\u0438\u0440\u0435\u043d\u043d\u044f \u043a\u043e\u043d\u0444\u0456\u0433\u0443\u0440\u0430\u0446\u0456\u0439 \u043f\u043e\u043b\u0438\u0446\u044c.",
  "about_limitations_title": "\u041e\u0431\u043c\u0435\u0436\u0435\u043d\u043d\u044f",
  "about_limitation_deck_only": "\u0426\u0435\u0439 \u043f\u043b\u0430\u0433\u0456\u043d \u043f\u0440\u0438\u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0439 \u043b\u0438\u0448\u0435 \u0434\u043b\u044f Steam Deck \u0443 \u0406\u0433\u0440\u043e\u0432\u043e\u043c\u0443 \u0440\u0435\u0436\u0438\u043c\u0456.",
  "about_limitation_decky": "\u041f\u043e\u0442\u0440\u0456\u0431\u043d\u043e \u0432\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0438 Decky Loader.",
  "about_limitation_home": "\u041f\u043e\u043b\u0438\u0446\u0456 \u0432\u0431\u0443\u0434\u043e\u0432\u0443\u044e\u0442\u044c\u0441\u044f \u0432 \u0413\u043e\u043b\u043e\u0432\u043d\u0438\u0439 \u0435\u043a\u0440\u0430\u043d \u0456 \u043c\u043e\u0436\u0443\u0442\u044c \u0431\u0443\u0442\u0438 \u0437\u0430\u0447\u0435\u043f\u043b\u0435\u043d\u0456 \u043e\u043d\u043e\u0432\u043b\u0435\u043d\u043d\u044f\u043c\u0438 \u043a\u043b\u0456\u0454\u043d\u0442\u0430 Steam.",
  "about_support_title": "\u041f\u0456\u0434\u0442\u0440\u0438\u043c\u0430\u0442\u0438 \u0440\u043e\u0437\u0440\u043e\u0431\u043d\u0438\u043a\u0430",
  "about_support_description": "\u042f\u043a\u0449\u043e \u0432\u0430\u043c \u043f\u043e\u0434\u043e\u0431\u0430\u0454\u0442\u044c\u0441\u044f \u0446\u0435\u0439 \u043f\u043b\u0430\u0433\u0456\u043d, \u0440\u043e\u0437\u0433\u043b\u044f\u043d\u044c\u0442\u0435 \u043c\u043e\u0436\u043b\u0438\u0432\u0456\u0441\u0442\u044c \u043f\u0456\u0434\u0442\u0440\u0438\u043c\u043a\u0438 \u043f\u043e\u0434\u0430\u043b\u044c\u0448\u043e\u0457 \u0440\u043e\u0437\u0440\u043e\u0431\u043a\u0438:",
  "about_changes_title": "\u041e\u0441\u0442\u0430\u043d\u043d\u0456 \u0437\u043c\u0456\u043d\u0438",
  "about_changes_description": "\u041e\u0441\u0442\u0430\u043d\u043d\u0456 \u043e\u043d\u043e\u0432\u043b\u0435\u043d\u043d\u044f: \u043f\u0443\u0431\u043b\u0456\u0447\u043d\u0438\u0439 API \u043f\u043b\u0430\u0433\u0456\u043d\u0430 \u0434\u043b\u044f \u0437\u043e\u0432\u043d\u0456\u0448\u043d\u0456\u0445 \u0434\u0436\u0435\u0440\u0435\u043b, \u0432\u0456\u0434\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u043d\u044f UnifiDeck, \u043f\u043e\u043a\u0440\u0430\u0449\u0435\u043d\u0430 \u0456\u043d\u0442\u0435\u0433\u0440\u0430\u0446\u0456\u044f \u0442\u0435\u0441\u0442\u0456\u0432 \u0442\u0430 CI (Vitest + pytest) \u0456 \u043f\u043e\u043a\u0440\u0430\u0449\u0435\u043d\u043d\u044f \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0437\u0430\u0446\u0456\u0457 \u0441\u043a\u0440\u0456\u043d\u0448\u043e\u0442\u0456\u0432 (\u043f\u0435\u0440\u0435\u043c\u0438\u043a\u0430\u043d\u043d\u044f \u043c\u043e\u0432 i18n \u0442\u0430 \u043f\u0435\u0440\u0435\u0432\u0456\u0440\u043a\u0438 CDP).",
  "about_version": "\u0412\u0435\u0440\u0441\u0456\u044f",
