  "about_feature_sources": "\u0417\u0430\u043f\u043e\u0432\u043d\u044e\u0439\u0442\u0435 \u043f\u043e\u043b\u0438\u0446\u0456 \u0437 \u043a\u043e\u043b\u0435\u043a\u0446\u0456\u0439, \u0440\u043e\u0437\u0434\u0456\u043b\u0456\u0432 \u0431\u0456\u0431\u043b\u0456\u043e\u0442\u0435\u043a\u0438 \u0430\u0431\u043e \u0440\u043e\u0437\u0448\u0438\u0440\u0435\u043d\u0438\u0445 \u0444\u0456\u043b\u044c\u0442\u0440\u0456\u0432",
  "about_feature_filters": "\u0424\u0456\u043b\u044c\u0442\u0440\u0443\u0439\u0442\u0435 \u0437\u0430 \u043d\u0430\u0437\u0432\u043e\u044e, \u0447\u0430\u0441\u043e\u043c \u0433\u0440\u0438, \u0441\u0442\u0430\u0442\u0443\u0441\u043e\u043c \u0432\u0441\u0442\u0430\u043d\u043e\u0432\u043b\u0435\u043d\u043d\u044f, \u0441\u0443\u043c\u0456\u0441\u043d\u0456\u0441\u0442\u044e, \u0432\u0438\u0434\u0438\u043c\u0456\u0441\u0442\u044e \u0442\u0430 \u0456\u043d\u0448\u0438\u043c",
  "about_feature_sort": "\u0421\u043e\u0440\u0442\u0443\u0439\u0442\u0435 \u0456\u0433\u0440\u0438 \u0437\u0430 \u0430\u043b\u0444\u0430\u0432\u0456\u0442\u043e\u043c \u0430\u0431\u043e \u0437\u0430 \u043e\u0441\u0442\u0430\u043d\u043d\u044c\u043e\u044e \u0441\u0435\u0441\u0456\u0454\u044e",
  "about_feature_reorder": "\u041f\u0435\u0440\u0435\u0432\u043f\u043e\u0440\u044f\u0434\u043a\u043e\u0432\u0443\u0439\u0442\u0435 \u043f\u043e\u043b\u0438\u0446\u0456 \u043f\u0435\u0440\u0435\u0442\u044f\u0433\u0443\u0432\u0430\u043d\u043d\u044f\u043c",
  "about_feature_visibility": "\u041f\u043e\u043a\u0430\u0437\u0443\u0439\u0442\u0435 \u0430\u0431\u043e \u043f\u0440\u0438\u0445\u043e\u0432\u0443\u0439\u0442\u0435 \u043e\u043a\u0440\u0435\u043c\u0456 \u043f\u043e\u043b\u0438\u0446\u0456 \u0431\u0435\u0437 \u0457\u0445 \u0432\u0438\u0434\u0430\u043b\u0435\u043d\u043d\u044f",
