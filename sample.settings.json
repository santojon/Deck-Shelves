    "smartSurpriseMe": false,
    "smartSurpriseMeCount": 0,
    "savedFilters": [
      {
        "id": "saved-filter-installed-games",
        "name": "Installed games (Steam)",
        "group": {
          "mode": "and",
          "items": [
            { "type": "installed", "inverted": false, "params": {} },
            { "type": "shortcutType", "inverted": false, "params": { "kinds": ["game"] } }
          ]
        }
      }
    ],
    "updateNotifyEnabled": true
  }
}
