bin/
backend/out/

# Environment (secrets)
.env
.env.*
!.env.example

# Build files
build/*

# Deploy staging
.deploy/
*.zip

# Local validation reports (with Deck — not committed)
site/reports/local/
# Temp files inside any reports subfolder
site/reports/**/.tmp_*/
site/reports/**/.tmp_*.json
# Top-level aggregate views — static client-side shells that fetch each
# scope's runs-manifest.json at view time, so they display any run without
# regeneration. Not committed; regenerate on demand with `pnpm reports:rebuild`.
site/reports/index.html
site/reports/dashboard.html

# Features page — generated by scripts/site/build_site.py on deploy
# (release notes/version are injected into site/index.html in place).
site/features.html

# Shared images copied from assets/ into the Pages tree by build_site.py.
# Source of truth is assets/icon.svg + assets/steam-deck.png; these are
# generated so the repo holds each image once.
site/favicon.svg
site/img/steam-deck.png

# Hidden folders
/.*/
!.github/
