{
  "name": "deck-shelves",
  "version": "1.2.4",
  "description": "Decky Loader plugin that injects configurable shelves into Steam Deck Home and provides a Steam Deck focused QAM editor.",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/build/build-decky.mjs --mode development",
    "build:plugin": "pnpm run build",
    "build:release": "node scripts/build/build-decky.mjs --mode production",
    "watch": "node scripts/build/build-decky.mjs --watch --mode development",
    "package": "bash scripts/build/package.sh",
    "dist": "pnpm run package",
    "verify:package": "bash scripts/build/verify-package.sh",
    "deploy:deck": "bash scripts/deploy/deploy-deck.sh",
    "deploy:deck:hard": "bash scripts/deploy/deploy-deck.sh --hard",
    "upload:deckzip": "bash scripts/deploy/upload-deck-zip.sh",
    "watch:deck": "node scripts/deck/watch-deck.mjs",
    "watch:deck:hard": "node scripts/deck/watch-deck.mjs --hard",
    "restart:steam": "bash scripts/deck/restart-steam.sh",
    "deck:setup": "bash scripts/deploy/deck-setup.sh",
    "fix:deck:perms": "bash scripts/deck/fix-deck-perms.sh",
    "deck:check": "bash scripts/deck/deck-check.sh",
    "deck:perf": "bash scripts/deck/perf-test.sh",
    "logs:decky": "bash scripts/deck/logs-decky.sh",
    "check": "pnpm run typecheck && node scripts/build/validate.mjs",
    "validate:compat": "bash scripts/build/validate-compat.sh",
    "screenshots": "python3 scripts/devtools/deck/cli.py screenshot",
    "screenshots:validate": "node scripts/build/validate-screenshots.mjs",
    "devtools:cli": "python3 scripts/devtools/deck/cli.py",
    "devtools:screenshots": "python3 scripts/devtools/deck/cli.py screenshot",
    "devtools:diag": "python3 scripts/devtools/deck/cli.py diag list",
    "test:all": "pnpm run test && python3 -m pip install -U pip setuptools && python3 -m pip install pytest && python3 -m pytest src/test/ -v",
    "clean": "rm -rf build dist .deploy build/package *.zip",
    "precommit": "pnpm run typecheck && pnpm run test && pnpm run build:release && pnpm run validate:compat && node scripts/build/validate-screenshots.mjs 2>/dev/null || true",
    "deploy:verify": "pnpm run deploy:deck:hard && sleep 20 && pnpm run devtools:cli -- probe --mode smoke",
    "update": "pnpm update --latest && pnpm update --latest --dev && pnpm install",
    "update:safe": "pnpm update && pnpm install",
    "update:check": "pnpm outdated"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santojon/Deck-Shelves.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "steam-deck",
    "shelves",
    "collections"
  ],
  "author": "Jonathan Santos",
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@decky/ui": "^4.11.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "jsdom": "29.0.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "ws": "^8.20.0"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "i18next": "^26.0.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "^17.0.2",
    "tslib": "^2.8.1",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "glob": "^13.0.0",
      "rimraf": "^6.0.1",
      "globby": "^14.1.0"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
