{
  "name": "deck-shelves",
  "version": "2.4.3",
  "description": "Decky Loader plugin that injects configurable shelves into Steam Deck Home and provides a Steam Deck focused QAM editor.",
  "type": "module",
  "scripts": {
    "validate:full": "bash scripts/ci/validate.sh",
    "validate:full:stress": "bash scripts/ci/validate.sh --stress",
    "validate:ci": "bash scripts/ci/validate-ci.sh",
    "reports": "open reports/index.html 2>/dev/null || xdg-open reports/index.html 2>/dev/null || echo 'Open reports/index.html manually'",
    "reports:serve": "echo 'Serving reports/ at http://localhost:8765/ (Ctrl-C to stop)' && (sleep 1 && (open http://localhost:8765/ 2>/dev/null || xdg-open http://localhost:8765/ 2>/dev/null) &) && python3 -m http.server -d reports 8765",
    "reports:rebuild": "python3 scripts/ci/report.py --rebuild --root .",
    "test": "NODE_NO_WARNINGS=1 vitest run",
    "typecheck": "tsc --noEmit",
    "lint:complexity": "eslint --no-warn-ignored --pass-on-unpruned-suppressions 'src/**/*.{ts,tsx}'",
    "lint:js": "eslint --no-warn-ignored --pass-on-unpruned-suppressions 'src/**/*.{ts,tsx}'",
    "lint:js:prune": "eslint --no-warn-ignored --prune-suppressions 'src/**/*.{ts,tsx}'",
    "lint:py": "python3 -m ruff check main.py scripts/ && python3 scripts/build/check-py-file-size.py",
    "lint:py:size": "python3 scripts/build/check-py-file-size.py",
    "lint": "pnpm run lint:js && pnpm run lint:py",
    "upgrade": "node scripts/build/upgrade-pnpm.cjs && pnpm --version",
    "upgrade:api": "bash -c 'cd api && node scripts/upgrade-pnpm.cjs && pnpm --version'",
    "build": "node scripts/build/build-decky.mjs --mode development",
    "build:plugin": "pnpm run build",
    "build:release": "node scripts/build/build-decky.mjs --mode production",
    "watch": "node scripts/build/build-decky.mjs --watch --mode development",
    "qa:first-run": "DS_QA_FORCE_FIRST_RUN=1 pnpm run deploy:deck:hard",
    "qa:qam-error": "DS_QA_FORCE_QAM_ERROR=1 pnpm run deploy:deck:hard",
    "qa:shelf-error": "DS_QA_FORCE_SHELF_ERROR=1 pnpm run deploy:deck:hard",
    "qa:all-shelves-hide-recents": "DS_QA_FORCE_ALL_SHELVES_HIDE_RECENTS=1 pnpm run deploy:deck:hard",
    "qa:all-shelves-show-recents": "DS_QA_FORCE_ALL_SHELVES_SHOW_RECENTS=1 pnpm run deploy:deck:hard",
    "qa:all-shelves-hide-home-tabs": "DS_QA_FORCE_ALL_SHELVES_HIDE_HOME_TABS=1 pnpm run deploy:deck:hard",
    "qa:all-shelves-show-home-tabs": "DS_QA_FORCE_ALL_SHELVES_SHOW_HOME_TABS=1 pnpm run deploy:deck:hard",
    "qa:smart-fixture": "DS_QA_SMART_SHELVES_FIXTURE=1 pnpm run deploy:deck:hard",
    "qa:saved-filters-fixture": "DS_QA_SAVED_FILTERS_FIXTURE=1 pnpm run deploy:deck:hard",
    "qa:hidden-shelf": "DS_QA_FORCE_HIDDEN_SHELF=1 pnpm run deploy:deck:hard",
    "qa:surprise-me": "DS_QA_SMART_SURPRISE_ME=1 pnpm run deploy:deck:hard",
    "qa:home-crash": "DS_QA_FORCE_HOME_CRASH=1 pnpm run deploy:deck:hard",
    "qa:replace-failed": "DS_QA_FORCE_REPLACE_FAILED=1 pnpm run deploy:deck:hard",
    "qa:update-available": "DS_QA_UPDATE_AVAILABLE=1 pnpm run deploy:deck:hard",
    "qa:update-dismissed": "DS_QA_UPDATE_AVAILABLE=1 DS_QA_UPDATE_DISMISSED=1 pnpm run deploy:deck:hard",
    "qa:update-offline": "DS_QA_UPDATE_OFFLINE=1 pnpm run deploy:deck:hard",
    "qa:collection-empty": "DS_QA_COLLECTION_EMPTY=1 pnpm run deploy:deck:hard",
    "qa:collection-inverted": "DS_QA_COLLECTION_INVERTED=1 pnpm run deploy:deck:hard",
    "qa:sources-fixture": "DS_QA_SOURCES_FIXTURE=1 pnpm run deploy:deck:hard",
    "qa:templates-fixture": "DS_QA_TEMPLATES_FIXTURE=1 pnpm run deploy:deck:hard",
    "qa:stress-fixture": "DS_QA_STRESS_FIXTURE=1 pnpm run deploy:deck:hard",
    "uitests": "pnpm --filter deckprobe uitests",
    "uitests:list": "pnpm --filter deckprobe uitests:list",
    "uitests:stress": "pnpm --filter deckprobe uitests -- --only stress",
    "perf:bench": "pnpm --filter deckprobe perf:bench",
    "package": "python3 scripts/build/package.py",
    "dist": "pnpm run package",
    "verify:package": "python3 scripts/build/verify-package.py",
    "deploy:deck": "bash scripts/deploy/deploy-deck.sh",
    "deploy:deck:hard": "bash scripts/deploy/deploy-deck.sh --hard",
    "upload:deckzip": "bash scripts/deploy/upload-deck-zip.sh",
    "watch:deck": "node scripts/deck/watch-deck.mjs",
    "watch:deck:hard": "node scripts/deck/watch-deck.mjs --hard",
    "restart:steam": "bash scripts/deck/restart-steam.sh",
    "deck:setup": "bash scripts/deploy/deck-setup.sh",
    "fix:deck:perms": "bash scripts/deck/fix-deck-perms.sh",
    "deck:check": "bash scripts/deck/deck-check.sh",
    "deck:perf": "bash scripts/deck/perf-test.sh",
    "logs:decky": "bash scripts/deck/logs-decky.sh",
    "check": "pnpm run typecheck && node scripts/build/validate.mjs",
    "dev:check": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "validate:compat": "node scripts/build/validate-compat.mjs",
    "screenshots": "pnpm --filter deckprobe screenshots",
    "screenshots:validate": "node scripts/build/validate-screenshots.mjs",
    "devtools:cli": "pnpm --filter deckprobe cli --",
    "devtools:screenshots": "pnpm --filter deckprobe screenshots",
    "devtools:diag": "pnpm --filter deckprobe diag",
    "test:all": "pnpm run test && python3 -m pip install -U pip setuptools && python3 -m pip install pytest && python3 -m pytest src/test/ -v",
    "clean": "rm -rf build dist .deploy build/package *.zip",
    "precommit": "pnpm run typecheck && pnpm run lint && pnpm run test:all && pnpm run build:release && pnpm run validate:compat && node scripts/build/validate-screenshots.mjs",
    "deploy:verify": "pnpm run deploy:deck:hard && sleep 20 && pnpm run devtools:cli -- probe --mode smoke",
    "update": "bash scripts/devtools/update.sh all",
    "update:all": "YES=1 bash scripts/devtools/update.sh all",
    "update:check": "bash scripts/devtools/update.sh check",
    "update:pnpm": "bash scripts/devtools/update.sh pnpm",
    "update:safe": "bash scripts/devtools/update.sh safe",
    "update:major": "bash scripts/devtools/update.sh major",
    "update:verify": "bash scripts/devtools/update.sh verify"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santojon/Deck-Shelves.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "steam-deck",
    "shelves",
    "collections"
  ],
  "author": "Jonathan Santos",
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@decky/ui": "^4.11.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "i18next": "^26.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "^17.0.8",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "glob": "^13.0.0",
      "rimraf": "^6.0.1",
      "globby": "^14.1.0",
      "postcss": "^8.5.10"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
